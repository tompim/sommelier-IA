# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer .env sur GitHub !

# Clé API Anthropic (obligatoire)
# Obtenir sur : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Identifiants CellarTracker (optionnel — si absent, utilise les données pré-chargées)
# Permet de recharger automatiquement votre cave à jour
CELLARTRACKER_USER=votre_identifiant
CELLARTRACKER_PASS=votre_mot_de_passe

# Port local (optionnel, défaut : 3000)
PORT=3000
